# Copy this file to .env and fill in real values. Do NOT commit .env to version control.

# Server (backend) API keys
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Optional settings
PORT=5000
NODE_ENV=development

# Frontend (client) - if you need runtime keys for the client, put them here
# VITE_ prefixed vars are exposed to the browser. Keep secrets on the server.
# VITE_SOME_PUBLIC_KEY=your_value
